// 环境变量模板
// 复制此文件为 .env 并填入实际值

# ==================== 前端 ====================
NEXT_PUBLIC_API_URL=http://localhost:8080/api
NEXT_PUBLIC_AI_URL=http://localhost:8000/api/ai

# ==================== AI服务 ====================
OPENAI_API_KEY=sk-your-openai-key
CHAT_MODEL=gpt-4
EMBEDDING_MODEL=text-embedding-ada-002

# ==================== 数据库 ====================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=travel_ai
DB_USER=travel
DB_PASSWORD=travel123

# ==================== Redis ====================
REDIS_HOST=localhost
REDIS_PORT=6379

# ==================== Milvus ====================
MILVUS_HOST=localhost
MILVUS_PORT=19530

# ==================== Elasticsearch ====================
ES_HOST=localhost
ES_PORT=9200

# ==================== 支付 ====================
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_PRIVATE_KEY=your-alipay-private-key
WECHAT_PAY_MCH_ID=your-wechat-mch-id
WECHAT_PAY_KEY=your-wechat-pay-key

# ==================== 短信 ====================
ALIYUN_SMS_ACCESS_KEY=your-access-key
ALIYUN_SMS_ACCESS_SECRET=your-access-secret
ALIYUN_SMS_SIGN_NAME=TravelAI
ALIYUN_SMS_TEMPLATE_CODE=SMS_123456789

# ==================== 翻译 ====================
GOOGLE_TRANSLATE_KEY=your-google-translate-key
